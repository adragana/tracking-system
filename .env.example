# Tracking System - Environment Variables Example

# DATABASE
DB_URL=jdbc:postgresql://postgres:5432/tracking_system
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT
# Base64-encoded secret key (min. 32 characters HS256)
JWT_SECRET=your_secret_key
# Expiration in ms (86400000 = 24h)
JWT_EXPIRATION=86400000

# POSTGRES (Docker)
POSTGRES_DB=tracking_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password